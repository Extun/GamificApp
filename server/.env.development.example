# ============================================================
# Plantilla de entorno LOCAL de desarrollo/QA (MODO A).
#
# Cómo usarla:
#   1. Copia este archivo como  server/.env   (dotenv carga .env, no este).
#   2. Deja los valores tal cual para apuntar al MySQL del contenedor
#      docker-compose.dev.yml (puerto host 3307, base gamificapp_dev).
#
# Estas credenciales son EXCLUSIVAS de desarrollo local y ficticias.
# server/.env está en .gitignore: nunca se sube al repositorio.
# NUNCA pongas aquí credenciales de Aiven/producción.
# ============================================================

PORT=3001

# El frontend de Vite en local.
CORS_ORIGIN=http://localhost:5173

# --- MySQL LOCAL del contenedor (docker-compose.dev.yml) ---
DB_HOST=localhost
DB_PORT=3307
DB_USER=gamificapp_dev
DB_PASSWORD=dev_local_pass
DB_NAME=gamificapp_dev

# Firma JWT: cualquier cadena larga sirve en local (NO reutilices la de prod).
JWT_SECRET=dev-solo-local-cambia-esta-cadena-larga-aleatoria-000000
JWT_EXPIRES_IN=8h

# Contraseña de la cuenta admin base que initDb.js crea al arrancar.
ADMIN_PASSWORD=admin-dev-local

# --- IA: sin claves reales en local. La generación con IA NO se valida
# localmente (queda como "no validado"); ver docs/DEV-ENTORNO-LOCAL.md §15.
GEMINI_API_KEY=
OPENAI_API_KEY=
IA_PROVEEDOR=gemini
IA_MODELO=

# El botón RESET permanece deshabilitado también en local salvo que lo
# necesites deliberadamente.
RESET_HABILITADO=false

# --- Bandera de siembra de datos dev (Fase L3, aún no implementada) ---
# El futuro server/scripts/seedDev.js exigirá DEV_SEED=true, NODE_ENV≠production
# y DB_HOST local para ejecutarse. Déjala comentada hasta usar el seed.
# DEV_SEED=true
