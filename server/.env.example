# Copia este archivo como .env y completa tus credenciales reales.
# server/.env está en .gitignore: NUNCA se sube al repositorio.
PORT=3001

# Orígenes permitidos (varios separados por coma, sin barra final).
CORS_ORIGIN=http://localhost:5173

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=gamificapp

# Firma de los JWT (obligatoria): usa una cadena larga y aleatoria.
JWT_SECRET=
JWT_EXPIRES_IN=8h

# Contraseña de la cuenta admin (initDb la crea/actualiza al arrancar).
ADMIN_PASSWORD=

# ---- Proveedores de IA (SPEC-016) ------------------------------------------
# Las API keys viven SOLO aquí, en el servidor: nunca se guardan en la base de
# datos ni se devuelven por ningún endpoint. El administrador elige proveedor y
# modelo desde el panel, jamás secretos.
GEMINI_API_KEY=
OPENAI_API_KEY=

# Proveedor activo: 'gemini' (por defecto) u 'openai'.
# Desde la Fase 3 esto se configura desde el panel de administración y esta
# variable pasa a ser solo el valor inicial.
IA_PROVEEDOR=gemini

# Modelo a usar. Vacío = automático (Gemini descubre el mejor "flash" de la
# cuenta; OpenAI usa gpt-4o-mini).
IA_MODELO=

# Habilita POST /api/admin/reset ("Restablecer aplicación", SPEC-008).
# ⚠️ Borra casi toda la base de datos (con backup previo automático). Déjala
# en 'false' o sin definir salvo que necesites usar el botón deliberadamente.
RESET_HABILITADO=false
